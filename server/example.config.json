{
  "apiPort": 3000,
  "webdavPort": 1900,
  "useSSL": false,
  "serverDirectory": "/",
  "failedLoginLimit": 5,
  "selfUsernameChanges": true,
  "filterMetadata": true,
  "globalExclusions": [
    "/bin/**",
    "/boot/**",
    "/dev/**",
    "/etc/**",
    "/lib/**",
    "/lib64/**",
    "/proc/**",
    "/root/**",
    "/run/**",
    "/sbin/**",
    "/sys/**",
    "/usr/**",
    "/var/**",
    "/tmp/**",
    "/opt/**",
    "/lost+found/**",
    "**/.ssh/**",
    "**/.gnupg/**"
  ],
  "globalExclusionBypasses": [
    "/var/www/**",
    "/etc/nginx/**"
  ]
}