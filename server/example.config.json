{
  "api": {
    "port": 3000,
    "allowedOrigins": ["http://localhost:3001"]
  },
  "webdav": {
    "enabled": true,
    "port": 1900
  },
  "ftp": {
    "enabled": false,
    "port": 2100
  },
  "useSSL": false,
  "serverDirectory": "/",
  "failedLoginLimit": 5,
  "selfUsernameChanges": true,
  "filterMetadata": true,
  "globalExclusions": [
    "/bin/**",
    "/boot/**",
    "/dev/**",
    "/etc/**",
    "/lib/**",
    "/lib64/**",
    "/proc/**",
    "/root/**",
    "/run/**",
    "/sbin/**",
    "/sys/**",
    "/usr/**",
    "/var/**",
    "/tmp/**",
    "/opt/**",
    "/lost+found/**",
    "**/.ssh/**",
    "**/.gnupg/**"
  ],
  "globalExclusionBypasses": [
    "/var/www/**",
    "/etc/nginx/**"
  ]
}